# Database
DATABASE_URL=sqlite+aiosqlite:////app/data/database.db

# MQTT
MQTT_BROKER_HOST=mqtt
MQTT_BROKER_PORT=1883
MQTT_TOPIC=isic/scan
MQTT_CLIENT_ID=isic-backend

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Application
APP_NAME=ISIC Backend
APP_VERSION=0.1.0
DEBUG=false

# Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRY_HOURS=24
CORS_ORIGINS=*
ADMIN_EMAIL=admin@stuba.sk
ADMIN_PASSWORD=change-me-in-production

# Scan Window
SCAN_WINDOW_BEFORE_MINUTES=15
SCAN_WINDOW_AFTER_MINUTES=5
